classDiagram
    class Task {
        +int task_id
        +str description
        +str time
        +str frequency
        +bool completed
        +str status
        +Pet pet
        +edit_task(**kwargs)
        +delete_task()
        +mark_complete()
    }

    class Pet {
        +int pet_id
        +str name
        +Optional[int] age
        +Optional[str] birth_date
        +Optional[str] breed
        +str species
        +Owner owner
        +Task[] tasks
        +update_pet_info(**kwargs)
        +add_task(task)
    }

    class Owner {
        +int owner_id
        +str name
        +Optional[str] join_date
        +Pet[] pets
        +add_pet(pet)
        +schedule_task(task, pet=None)
        +view_schedule()
        +get_all_tasks()
        +filter_tasks(completed=None, pet_name=None)
    }

    class Scheduler {
        +Owner owner
        +Pet pet
        +Task[] tasks
        +add_task(task)
        +sort_by_time(tasks=None)
        +view_schedule()
        +check_conflicts()
    }

    Owner "1" --> "*" Pet : pets
    Pet "1" --> "*" Task : tasks
    Task --> Pet : pet
    Scheduler --> Owner : owner
    Scheduler --> Pet : pet
    Scheduler --> Task : tasks

    note right of Task : mark_complete() creates a new recurring task for daily/weekly frequency
